page {
  background-color: #fff;
  color: #333;
}

.container {
  padding: 0;
  width: 100%;
  opacity: 0;
  transform: translateY(15px);
  transition: all 0.6s ease-out;
}

.animation-ready {
  opacity: 1;
  transform: translateY(0);
}

/* 地点图片 */
.location-image {
  width: 100%;
  height: 250px;
  overflow: hidden;
  position: relative;
}

.location-image:after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 30px;
  background: linear-gradient(to top, #fff, transparent);
  z-index: 1;
}

.location-img {
  width: 100%;
  height: 100%;
  transition: transform 12s ease-in-out;
}

.animation-ready .location-img {
  transform: scale(1.05);
}

/* 占位图 */
.placeholder-img {
  background: linear-gradient(135deg, #a85418, #c47a3a);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24px;
  font-weight: bold;
}

/* 地点内容 */
.location-content {
  padding: 15px;
  position: relative;
  z-index: 2;
}

.location-content:before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: repeating-linear-gradient(45deg, rgba(168, 84, 24, 0.03) 0px, rgba(168, 84, 24, 0.03) 1px, transparent 1px, transparent 11px),
                    repeating-linear-gradient(135deg, rgba(168, 84, 24, 0.03) 0px, rgba(168, 84, 24, 0.03) 1px, transparent 1px, transparent 11px);
  z-index: -1;
}

.location-title {
  font-size: 20px;
  font-weight: bold;
  color: #a85418;
  margin-bottom: 10px;
  padding-bottom: 8px;
  border-bottom: 1px solid #eee;
  text-align: center;
  position: relative;
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.5s ease 0.1s;
}

.animation-ready .location-title {
  opacity: 1;
  transform: translateY(0);
}

.location-title:after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -1px;
  width: 60px;
  height: 2px;
  background-color: #a85418;
  transform: translateX(-50%);
}

/* 元信息 */
.location-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.5s ease 0.15s;
}

.animation-ready .location-meta {
  opacity: 1;
  transform: translateY(0);
}

.meta-category {
  font-size: 12px;
  color: #fff;
  background-color: #a85418;
  padding: 2px 10px;
  border-radius: 10px;
}

.meta-address {
  font-size: 12px;
  color: #999;
}

/* 地点描述 */
.location-desc {
  font-size: 14px;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20px;
  padding: 10px;
  background-color: rgba(168, 84, 24, 0.05);
  border-radius: 8px;
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.5s ease 0.2s;
}

.animation-ready .location-desc {
  opacity: 1;
  transform: translateY(0);
}

/* 非遗项目区块 */
.section {
  margin-bottom: 20px;
  opacity: 0;
  transform: translateY(15px);
  transition: all 0.5s ease 0.3s;
}

.animation-ready .section {
  opacity: 1;
  transform: translateY(0);
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #a85418;
  margin-bottom: 12px;
  position: relative;
  padding-left: 12px;
}

.section-title:before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4px;
  background-color: #a85418;
  border-radius: 2px;
}

.heritage-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.heritage-item {
  background-color: rgba(168, 84, 24, 0.03);
  border-radius: 8px;
  padding: 12px;
  border-left: 3px solid #a85418;
}

.heritage-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
}

.heritage-item-name {
  font-size: 15px;
  font-weight: bold;
  color: #333;
}

.heritage-item-status {
  font-size: 11px;
  color: #a85418;
  background-color: rgba(168, 84, 24, 0.08);
  padding: 2px 6px;
  border-radius: 4px;
}

.heritage-item-type {
  display: block;
  font-size: 12px;
  color: #999;
  margin-bottom: 6px;
}

.heritage-item-content {
  display: block;
  font-size: 13px;
  color: #666;
  line-height: 1.6;
}

/* 加载 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: #999;
  position: relative;
}

.loading:after {
  content: "";
  display: block;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  border: 2px solid rgba(168, 84, 24, 0.2);
  border-top-color: #a85418;
  animation: loading-spin 0.8s linear infinite;
  position: absolute;
  top: 50%;
  margin-top: -40px;
}

@keyframes loading-spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
